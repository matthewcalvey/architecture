  "file_role": "shared_code_baseline",
  "purpose": "Shared baseline of codes, standards, benchmark systems, and authoritative planning guides for all CALVEY program databases. Building-type JSONs should reference this file instead of duplicating source metadata.",
  "recommended_integration_pattern": {
    "new_top_level_key_in_each_building_type_json": "source_profiles",
    "code_reference_strategy": "Each building-type JSON references one or more shared profile IDs from this file plus any type-specific guide IDs.",
    "local_adoption_strategy": "Treat model codes as baseline only. Add project-specific jurisdiction overrides in a separate local_code_overrides file."
  },
